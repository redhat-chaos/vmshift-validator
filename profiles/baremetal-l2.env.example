# baremetal-l2 profile — SSH bastion routing for bare-metal labs
#
# Copy this file to baremetal-l2.env and fill in your values:
#   cp profiles/baremetal-l2.env.example profiles/baremetal-l2.env
#
# baremetal-l2.env is gitignored — your bastion details stay local.

# Source bastion — where vmshift-validator runs.
# Use "localhost" if running directly on the bastion.
SOURCE_BASTION="localhost"

# Source cluster kubeconfig path (on the source bastion).
SOURCE_BASTION_KUBECONFIG="/root/blue/kubeconfig"

# Target bastion — FQDN or IP of the target cluster's bastion.
# kubectl/virtctl commands for the target cluster are routed via SSH hop through this host.
TARGET_BASTION="target-bastion.example.com"

# Target cluster kubeconfig path (on the target bastion).
TARGET_BASTION_KUBECONFIG="/root/green/kubeconfig"

# SSH key for VM access (virtctl ssh identity file on the bastion).
# Must match the public key injected into VMs via cloud-init.
BASTION_SSH_KEY="/root/vmshift-validator/keys/kube-burner"

# Where Forklift Plan/Migration CRs are created.
# "source" if MTV is on the source cluster, "target" if on the target cluster.
MIGRATION_API="target"

# ── Sync settings (used by sync.sh) ─────────────────────
# SSH alias or FQDN of the bastion to push code to.
REMOTE_HOST="bastion-ssh-alias"

# Path on the bastion where vmshift-validator is deployed.
REMOTE_PATH="/root/vmshift-validator"
